rules_version = '2';
service cloud.firestore {
  function getCurrentUserId() {
    return request.auth.uid;
  }

  function isAuthenticated() {
    return request.auth != null;
  }

  match /databases/{database}/documents {
    function isTutorhubAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/tutorhub_admins/$(getCurrentUserId()));
    }

    match /visitors/{docId} {
      allow create: if true;
      allow read: if false;
    }

    match /tutorhub_posts/{docId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.authorId == getCurrentUserId();
      allow delete: if isAuthenticated() && resource.data.authorId == getCurrentUserId();
    }

    match /tutorhub_users/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && docId == getCurrentUserId();
    }

    match /tutorhub_likes/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /tutorhub_comments/{docId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && resource.data.authorId == getCurrentUserId();
    }

    match /tutorhub_notifications/{docId} {
      allow read: if isAuthenticated() && docId == getCurrentUserId();
      allow create: if true;
    }

    match /tutorhub_admins/{docId} {
      allow read: if isAuthenticated() && docId == getCurrentUserId();
      allow write: if false;
    }

    match /tutorhub_app_users/{docId} {
      allow read: if isAuthenticated() && (docId == getCurrentUserId() || isTutorhubAdmin());
      allow create: if isAuthenticated() && docId == getCurrentUserId();
      allow update: if isAuthenticated() && (docId == getCurrentUserId() || isTutorhubAdmin());
      allow delete: if false;
    }

    match /tutorhub_student_profiles/{docId} {
      allow read: if isAuthenticated() && (docId == getCurrentUserId() || isTutorhubAdmin());
      allow create: if isAuthenticated() && docId == getCurrentUserId();
      allow update: if isAuthenticated() && (docId == getCurrentUserId() || isTutorhubAdmin());
      allow delete: if isAuthenticated() && docId == getCurrentUserId();
    }

    match /tutorhub_teacher_profiles/{docId} {
      allow read: if isAuthenticated() && (
        resource.data.status == "approved" ||
        docId == getCurrentUserId() ||
        isTutorhubAdmin()
      );
      allow create: if isAuthenticated() && docId == getCurrentUserId();
      allow update: if isAuthenticated() && (docId == getCurrentUserId() || isTutorhubAdmin());
      allow delete: if isAuthenticated() && docId == getCurrentUserId();
    }

    match /tutorhub_wallets/{docId} {
      allow read: if isAuthenticated() && (docId == getCurrentUserId() || isTutorhubAdmin());
      allow create: if isAuthenticated() && docId == getCurrentUserId();
      allow update: if isAuthenticated() && (docId == getCurrentUserId() || isTutorhubAdmin());
      allow delete: if false;
    }

    match /tutorhub_wallet_transactions/{docId} {
      allow read: if isAuthenticated() && (
        resource.data.uid == getCurrentUserId() || isTutorhubAdmin()
      );
      allow create: if isAuthenticated() && (
        request.resource.data.uid == getCurrentUserId() || isTutorhubAdmin()
      );
      allow update, delete: if false;
    }

    match /tutorhub_bookings/{docId} {
      allow read: if isAuthenticated() && (
        resource.data.studentId == getCurrentUserId() ||
        resource.data.teacherId == getCurrentUserId() ||
        isTutorhubAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.studentId == getCurrentUserId();
      allow update: if isAuthenticated() && (
        resource.data.studentId == getCurrentUserId() ||
        resource.data.teacherId == getCurrentUserId() ||
        isTutorhubAdmin()
      );
      allow delete: if isTutorhubAdmin();
    }

    match /forumMessages/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    match /devMessages/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    match /devOnline/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}